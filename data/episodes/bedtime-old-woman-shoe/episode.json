      "text": "The old woman looked at him for a minute very angrily, then burst into tears.",
      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-047",
      "startTime": 218.88000000000002,
      "endTime": 225.24,
      "text": "\"'Oh, the little werches!' she cried, \"'they do lead me alive.",
      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-048",
      "startTime": 225.24,
      "endTime": 231.60000000000002,
      "text": "Oh dear, oh dear, oh dear, oh dear, I've got so many children.",
      "translationHint": "",
