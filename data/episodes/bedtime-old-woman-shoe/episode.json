      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-042",
      "startTime": 191.36,
      "endTime": 197.8,
      "text": "\"'Hey,' cried Dandelion, \"'stop that!' in her astonishment.",
      "translationHint": "",
