      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-050",
      "startTime": 234.16,
      "endTime": 237.08,
