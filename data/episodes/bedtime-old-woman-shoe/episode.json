      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-029",
      "startTime": 133.12,
      "endTime": 138.12,
      "text": "\"'You do make lovely broth, Mom,' said Clover, smacking his lips.",
      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-030",
      "startTime": 138.12,
      "endTime": 139.72,
      "text": "\"'Not half!' cried the door.",
      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
