      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-040",
      "startTime": 178.56,
      "endTime": 184.72,
      "text": "Dandelion crept nearer, and, looking through a little hole in the heel, was just in time",
      "translationHint": "",
