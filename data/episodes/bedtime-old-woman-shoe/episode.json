      "endTime": 142.28,
      "text": "With the other five little goblins altogether.",
      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-032",
      "startTime": 142.28,
      "endTime": 146.12,
      "text": "\"'That's right,' said the little goblin woman.",
      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
      "id": "seg-033",
      "startTime": 146.12,
      "endTime": 149.92,
      "text": "\"'Goodbye, Dandelion, lovey, don't be gone all night.",
      "translationHint": "",
      "keywords": [],
      "phraseNotes": [],
      "wordTimings": [],
      "enabledForPractice": true,
      "contentType": "main"
    },
    {
